# ローカル開発用の secret サンプル。
#   cp .dev.vars.example .dev.vars
# して値を入れると `wrangler dev` が読み込む。.dev.vars はコミットしないこと。
# 本番は `wrangler secret put INGEST_TOKEN` で登録する。

INGEST_TOKEN="change-me-to-a-long-random-token"

# vars はデフォルトを wrangler.jsonc に置いてあるので通常は不要。
# ローカルで上書きしたいときだけ設定する。
# ANU_API_URL="https://qrng.anu.edu.au/API/jsonI.php"
# ANU_REFILL_LENGTH="1024"
