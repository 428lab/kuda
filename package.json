  "pnpm": {
    "//": "pnpm は依存の postinstall を既定でブロックする(サプライチェーン対策)。wrangler のビルドツールチェーンだけ明示的に許可し、他は遮断のまま。",
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  }
