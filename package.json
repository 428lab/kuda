{
  "name": "kuda",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "乱数の管 — Cloudflare Worker entropy pool (ANU QRNG API版)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node test/e2e.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^7.0.2",
    "vitest": "3.0.9",
    "wrangler": "^4.107.1"
  },
  "pnpm": {
    "//": "pnpm は依存の postinstall を既定でブロックする(サプライチェーン対策)。wrangler のビルドツールチェーンだけ明示的に許可し、他は遮断のまま。",
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "dependencies": {
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0"
  }
}
