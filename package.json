{
  "name": "kuda",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "乱数の管 — Cloudflare Worker entropy pool (ANU QRNG API版)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
